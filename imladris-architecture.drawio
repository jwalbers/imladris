  <diagram name="Imaging Workflow" id="vesotho-workflow-001">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Page title -->
        <mxCell id="title" value="End-to-End Imaging Workflow — MDR-TB Virtual Integration Lab" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1480" height="40" as="geometry" />
        </mxCell>

        <!-- ── Lane background bands ── -->
        <mxCell id="bg1" value="" style="rounded=0;html=1;fillColor=#fff0f0;strokeColor=#b85450;strokeOpacity=40;fillOpacity=60;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="220" height="940" as="geometry" />
        </mxCell>
        <mxCell id="bg2" value="" style="rounded=0;html=1;fillColor=#f0fff0;strokeColor=#82b366;strokeOpacity=40;fillOpacity=60;" vertex="1" parent="1">
          <mxGeometry x="260" y="120" width="220" height="940" as="geometry" />
        </mxCell>
        <mxCell id="bg3" value="" style="rounded=0;html=1;fillColor=#fffbf0;strokeColor=#d6b656;strokeOpacity=40;fillOpacity=60;" vertex="1" parent="1">
          <mxGeometry x="480" y="120" width="220" height="940" as="geometry" />
        </mxCell>
        <mxCell id="bg4" value="" style="rounded=0;html=1;fillColor=#fffff0;strokeColor=#d6b656;strokeOpacity=40;fillOpacity=60;" vertex="1" parent="1">
          <mxGeometry x="700" y="120" width="220" height="940" as="geometry" />
        </mxCell>
        <mxCell id="bg5" value="" style="rounded=0;html=1;fillColor=#f0f5ff;strokeColor=#6c8ebf;strokeOpacity=40;fillOpacity=60;" vertex="1" parent="1">
          <mxGeometry x="920" y="120" width="220" height="940" as="geometry" />
        </mxCell>
        <mxCell id="bg6" value="" style="rounded=0;html=1;fillColor=#f8f0ff;strokeColor=#9673a6;strokeOpacity=40;fillOpacity=60;" vertex="1" parent="1">
          <mxGeometry x="1140" y="120" width="220" height="940" as="geometry" />
        </mxCell>

        <!-- ── Lane headers ── -->
        <mxCell id="h1" value="Clinician" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="h2" value="OpenMRS" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="70" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="h3" value="Rad Tech" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#d6b656;strokeWidth=2;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="70" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="h4" value="DICOM Modality" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="70" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="h5" value="Cloud PACS" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="920" y="70" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="h6" value="Radiologist" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1140" y="70" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- ── Step boxes ── -->

        <!-- Row 1 (y=150): Order + Create MWL -->
        <mxCell id="s1" value="&lt;b&gt;1. Order Imaging&lt;/b&gt;&lt;br&gt;Select patient, choose&lt;br&gt;study type in OpenMRS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="150" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="&lt;b&gt;2. Create MWL Entry&lt;/b&gt;&lt;br&gt;Radiology Module generates&lt;br&gt;DICOM Worklist record" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="150" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- Row 2 (y=270): Rad Tech queries MWL -->
        <mxCell id="s3" value="&lt;b&gt;3. Query Worklist (C-FIND)&lt;/b&gt;&lt;br&gt;Pull pending exams from&lt;br&gt;OpenMRS MWL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#d6b656;strokeWidth=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="500" y="270" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- Row 3 (y=380): Trigger acquisition + Modality acquires -->
        <mxCell id="s4" value="&lt;b&gt;4. Trigger Acquisition&lt;/b&gt;&lt;br&gt;Select patient on modality,&lt;br&gt;initiate image capture" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#d6b656;strokeWidth=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="500" y="390" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s5" value="&lt;b&gt;5. Acquire Images&lt;/b&gt;&lt;br&gt;Simulator generates DICOM&lt;br&gt;series from TB dataset" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="390" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- Row 4 (y=510): C-STORE + PACS stores + OpenMRS notified -->
        <mxCell id="s6" value="&lt;b&gt;6. C-STORE SCU&lt;/b&gt;&lt;br&gt;Push study to Cloud PACS&lt;br&gt;via DIMSE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="510" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s7" value="&lt;b&gt;7. Index Study + Notify&lt;/b&gt;&lt;br&gt;PACS stores study, sends&lt;br&gt;HL7 ORM to OpenMRS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="940" y="510" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s8" value="&lt;b&gt;8. Mark Study Received&lt;/b&gt;&lt;br&gt;Order status updated,&lt;br&gt;radiologist worklist flagged" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="510" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- Row 5 (y=630): Radiologist fetches study -->
        <mxCell id="s9" value="&lt;b&gt;9. Fetch Study (WADO-RS)&lt;/b&gt;&lt;br&gt;OHIF retrieves DICOM images&lt;br&gt;from PACS via DICOMweb" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1160" y="630" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- Row 6 (y=750): Radiologist reads + submits report -->
        <mxCell id="s10" value="&lt;b&gt;10. Read &amp; Measure&lt;/b&gt;&lt;br&gt;Cavity size, consolidation,&lt;br&gt;WHO CXR score, comparison" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1160" y="750" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s11" value="&lt;b&gt;11. Submit Report&lt;/b&gt;&lt;br&gt;HL7 ORU / FHIR DiagnosticReport&lt;br&gt;signed &amp; stored in OpenMRS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="750" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- Row 7 (y=870): Clinician reviews -->
        <mxCell id="s12" value="&lt;b&gt;12. View Images (read-only)&lt;/b&gt;&lt;br&gt;OHIF read-only DICOMweb&lt;br&gt;access to Cloud PACS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="870" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s13" value="&lt;b&gt;13. Review Report&lt;/b&gt;&lt;br&gt;Access signed radiology report&lt;br&gt;and patient record in OpenMRS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="870" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- Row 8 (y=990): Clinical decision (terminal) -->
        <mxCell id="s14" value="&lt;b&gt;14. Clinical Decision&lt;/b&gt;&lt;br&gt;Drug regimen adjustment,&lt;br&gt;referral, or follow-up order" style="shape=mxgraph.flowchart.terminate;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="990" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- ── Edges ── -->

        <!-- s1 → s2 -->
        <mxCell id="w1" value="creates order" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#b85450;strokeWidth=2;fontSize=9;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="s1" target="s2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- s2 → s3 -->
        <mxCell id="w2" value="MWL available" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#82b366;strokeWidth=2;fontSize=9;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="s2" target="s3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- s3 → s4 -->
        <mxCell id="w3" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d6b656;strokeWidth=2;fontSize=9;" edge="1" source="s3" target="s4" parent="1">
          <mxGeometry relative="1" as="geometry" />
